# Copy to .env for local development. Never commit the real .env.

# --- Coordinator ---
DATABASE_URL=postgres://vless:vless@localhost:5432/vless_tester?sslmode=disable

# Integration tests pick up this URL; leave empty to skip DB-backed tests.
TEST_DATABASE_URL=postgres://vless:vless@localhost:5432/vless_tester?sslmode=disable

# MaxMind GeoLite2 credentials (DB downloaded and cached by the coordinator).
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=

# Dashboard login credentials. Users sign in with these; the coordinator mints a
# per-login session token (held in memory, not persisted) that the dashboard
# uses as its bearer. ADMIN_USER defaults to "admin". When ADMIN_PASSWORD is
# empty the admin plane is UNAUTHENTICATED (dev only) — set it in any real deploy.
ADMIN_USER=admin
ADMIN_PASSWORD=

# Publish target: a SEPARATE GitHub repository for the working list.
GITHUB_PUBLISH_REPO=
GITHUB_TOKEN=

# --- Worker ---
COORDINATOR_URL=http://localhost:8080
# Optional SOCKS5 tunnel for the control channel only (restricted networks).
COORDINATOR_PROXY=
# Per-worker token minted in the admin panel (Workers section). It both
# authenticates the worker and fixes its name/identity in the fleet. Required.
WORKER_TOKEN=
# Ignored: the worker's identity comes from its token's name, set in the panel.
WORKER_ID=
# Concurrency knobs (optional; defaults in parentheses). Each concurrent job
# runs an in-process mihomo proxy (a few goroutines), so RAM scales with these.
#   WORKER_CAP_SPEED    concurrent speed tests (4). Each test saturates the
#                       proxied node, not your uplink, so raise it on fat links.
#   WORKER_CAP_LATENCY  concurrent latency probes + default claim batch size (200).
#   WORKER_BATCH        override the claim batch size (defaults to WORKER_CAP_LATENCY).
WORKER_CAP_SPEED=
WORKER_CAP_LATENCY=
WORKER_BATCH=
# Worker bandwidth in Mbps, reported to the coordinator for fleet sizing only
# (not throttled locally). Auto-measured via a baseline self-test when empty.
WORKER_BW_MBPS=
